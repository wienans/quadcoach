{
  "name": "quadcoach",
  "version": "1.0.0",
  "description": "QuadCoach - The digital assistant coach for Quadball",
  "main": "index.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.ts",
    "build": "npx tsc --build --clean && npx tsc",
    "test": "jest --runInBand",
    "typecheck": "tsc --noEmit",
    "verify:clean-artifacts": "ts-node --transpile-only scripts/verifyCleanArtifacts.ts",
    "verify": "npm test && npm run build && npm run verify:clean-artifacts",
    "collection:preflight": "ts-node collectionQuery/operations/preflightCli.ts",
    "collection:synthetic": "ts-node collectionQuery/operations/syntheticCli.ts",
    "collection:index:create": "ts-node collectionQuery/operations/indexCli.ts create",
    "collection:index:verify": "ts-node collectionQuery/operations/indexCli.ts verify",
    "collection:index:drop": "ts-node collectionQuery/operations/indexCli.ts drop"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.6",
    "date-fns": "^4.4.0",
    "express": "^4.22.2",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^8.5.2",
    "handlebars": "^4.7.9",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.18.1",
    "mongoose": "^9.7.1",
    "nodemailer": "^9.0.1",
    "uuid": "^11.1.1",
    "validator": "^13.15.35"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.24",
    "@types/nodemailer": "^8.0.1",
    "@types/supertest": "^7.2.0",
    "@types/validator": "^13.15.10",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
